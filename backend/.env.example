# Django
SECRET_KEY=change-me-in-production-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
DATABASE_URL=postgres://postgres:postgres@db:5432/urban_land

# Cache / Celery broker
REDIS_URL=redis://redis:6379/0

# Locale & currency
DEFAULT_CURRENCY=XOF
DEFAULT_LANGUAGE=fr
TIME_ZONE=Africa/Abidjan

# Company identity (apparait sur les recus/contrats)
COMPANY_NAME=Ma Societe Immobiliere SARL
COMPANY_ADDRESS=Abidjan, Cote d'Ivoire
COMPANY_PHONE=+225 00 00 00 00
COMPANY_EMAIL=contact@example.ci
COMPANY_RCCM=CI-ABJ-2026-B-00000
COMPANY_TAX_ID=00000000

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@example.ci

# SMS provider (Twilio par exemple - optionnel)
SMS_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Stockage des fichiers (par defaut local; S3 optionnel)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-west-1

# ==========================================================================
# Comptes par defaut (crees par la commande seed_demo_users)
# Mot de passe initial partage par tous les comptes seed. A changer apres
# la premiere connexion. Mettez DEMO_USERS_ENABLED=False en production pour
# desactiver totalement la creation des comptes de demonstration.
# ==========================================================================
DEMO_USERS_ENABLED=True
DEMO_USERS_PASSWORD=UrbanLand!2026

# Super administrateur (privileges systeme)
DEMO_SUPER_ADMIN_EMAIL=superadmin@urban-land.local
DEMO_SUPER_ADMIN_USERNAME=superadmin
DEMO_SUPER_ADMIN_FIRST_NAME=Super
DEMO_SUPER_ADMIN_LAST_NAME=Administrateur

# Administrateur (gere catalogue, utilisateurs, transactions)
DEMO_ADMIN_EMAIL=admin@urban-land.local
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_FIRST_NAME=Aline
DEMO_ADMIN_LAST_NAME=Administratrice

# Agent commercial (cree lots, gere clients, ouvre ventes)
DEMO_AGENT_EMAIL=agent@urban-land.local
DEMO_AGENT_USERNAME=agent
DEMO_AGENT_FIRST_NAME=Yao
DEMO_AGENT_LAST_NAME=Commercial

# Caissier (enregistre versements, imprime recus)
DEMO_CASHIER_EMAIL=caisse@urban-land.local
DEMO_CASHIER_USERNAME=caisse
DEMO_CASHIER_FIRST_NAME=Awa
DEMO_CASHIER_LAST_NAME=Caisse

# Lecteur (consultation uniquement)
DEMO_VIEWER_EMAIL=lecteur@urban-land.local
DEMO_VIEWER_USERNAME=lecteur
DEMO_VIEWER_FIRST_NAME=Kofi
DEMO_VIEWER_LAST_NAME=Lecteur
